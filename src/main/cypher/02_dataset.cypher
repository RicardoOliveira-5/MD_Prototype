// ============================================================
//  NYC SUBWAY — Dataset Real (MTA GTFS Oficial)
//  493 estações | 29 linhas
//  Fonte: Metropolitan Transportation Authority
//  Dados GTFS reais: stops, routes, trips, stop_times
// ============================================================

MATCH (n) DETACH DELETE n;

// ── CONSTRAINTS ─────────────────────────────────────────────
CREATE CONSTRAINT paragem_id IF NOT EXISTS FOR (n:Paragem) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT zona_id IF NOT EXISTS FOR (n:Zona) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT rota_id IF NOT EXISTS FOR (n:Rota) REQUIRE n.id IS UNIQUE;
CREATE CONSTRAINT evento_id IF NOT EXISTS FOR (n:Evento) REQUIRE n.id IS UNIQUE;

// ── ZONAS (BOROUGHS NYC) ─────────────────────────────────────
CREATE (:Zona { id:"Z_Manhattan", nome:"Manhattan", tipo:"Commercial", descricao:"Ilha central de NYC, maior concentração de escritórios", cidade:"New York City" });
CREATE (:Zona { id:"Z_Brooklyn", nome:"Brooklyn", tipo:"Residential", descricao:"Borough mais populoso de NYC", cidade:"New York City" });
CREATE (:Zona { id:"Z_Queens", nome:"Queens", tipo:"Mixed", descricao:"Borough mais diverso etnicamente", cidade:"New York City" });
CREATE (:Zona { id:"Z_Bronx", nome:"Bronx", tipo:"Residential", descricao:"Único borough no continente", cidade:"New York City" });
CREATE (:Zona { id:"Z_Staten_Island", nome:"Staten Island", tipo:"Residential", descricao:"Borough menos denso de NYC", cidade:"New York City" });

// ── PARAGENS (493 estações reais MTA) ─────────────────────
